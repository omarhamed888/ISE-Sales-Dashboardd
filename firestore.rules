rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return getRole() in ['admin', 'superadmin'];
    }
    
    function isSuperAdmin() {
      return getRole() == 'superadmin';
    }
    
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
    
    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuth() && resource.data.salesRepId == request.auth.uid);
      allow create: if isAuth();
      allow update: if false;
      allow delete: if isSuperAdmin();
    }
    
    match /excuses/{excuseId} {
      allow read: if isAdmin() || (isAuth() && resource.data.salesRepId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    match /attendance/{recordId} {
      allow read: if isAdmin() || (isAuth() && resource.data.salesRepId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
